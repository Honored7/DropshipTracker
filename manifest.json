{
  "manifest_version": 3,
  "name": "DropshipTracker - Multi-Cart Product Sync",
  "version": "2.0.0",
  "description": "Scrape products from any supplier site, track prices/stock, and export to CS-Cart, Shopify, WooCommerce, PrestaShop, Magento, or BigCommerce CSV/XML format with Google Drive sync",
  "author": "DropshipTracker",
  
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  
  "permissions": [
    "activeTab",
    "storage",
    "identity",
    "alarms",
    "downloads",
    "scripting",
    "webRequest"
  ],
  
  "host_permissions": [
    "*://*/*"
  ],
  
  "oauth2": {
    "client_id": "185058913956-463c2dcilpeno3vnm14ndotcric2414p.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "action": {
    "default_title": "DropshipTracker",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'sha256-wU69YSS4ukvyxK3Ing/VVNKmvvVRFq5blHbZfgAjWcM='; object-src 'self'"
  },

  "content_scripts": [
    {
      "matches": ["*://www.aliexpress.com/*", "*://www.aliexpress.us/*", "*://www.alibaba.com/*"],
      "js": ["page-interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["*://*/*"],
      "js": ["js/jquery-3.1.1.min.js", "js/sha256.min.js", "onload.js"],
      "css": ["onload.css"],
      "run_at": "document_end"
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "css/*", "js/*", "page-interceptor.js"],
      "matches": ["*://*/*"]
    }
  ]
}
